{
    "name": "nightjar/silverstripe-configcodes",
    "description": "Allows shortcodes to be defined and registered via config",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "CMS"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^6",
        "silverstripe/admin": "^3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "squizlabs/php_codesniffer": "^3",
        "cambis/silverstan": "^2.1",
        "slevomat/coding-standard": "^8.22"
    },
    "autoload": {
        "psr-4": {
            "Nightjar\\ConfigCodes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nightjar\\ConfigCodes\\Test\\": "tests/"
        }
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
