{
  "name": "silverstripe-semirich-text-shortcode-editor",
  "description": "Like a text field, but with some rich text type functions specifically for managing shortcodes",
  "main": "./client/src/boot/index.js",
  "author": "Dylan Wagstaff",
  "engines": {
    "node": ">=10.x"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -m -c",
    "watch": "rollup -wc",
    "lint": "eslint client/src && sass-lint client/src"
  },
  "dependencies": {
    "@bbob/parser": "^2.8.1",
    "is-hotkey": "^0.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "slate": "<1",
    "slate-history": "<1",
    "slate-react": "<1"
  },
  "peerDependencies": {
    "silverstripe-admin": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "silverstripe-admin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/preset-react": "^7.18.6",
    "@rollup/plugin-babel": "^6.0.2",
    "@rollup/plugin-commonjs": "^23.0.2",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@silverstripe/eslint-config": "^0.0.5",
    "rollup": "^3.2.3",
    "rollup-plugin-sass": "^1.12.16",
    "rollup-plugin-scss": "^3.0.0",
    "sass": "^1.56.0"
  },
  "jest": {
    "roots": [
      "client/src"
    ],
    "modulePaths": [
      "client/src",
      "../admin/client/src",
      "../admin/node_modules",
      "../silverstripe/admin/client/src",
      "../silverstripe/admin/node_modules",
      "../../silverstripe/admin/client/src",
      "../../silverstripe/admin/node_modules"
    ]
  }
}
