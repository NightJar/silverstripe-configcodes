{
  "name": "silverstripe-semirich-text-shortcode-editor",
  "description": "Like a text field, but with some rich text type functions specifically for managing shortcodes",
  "source": "client/src/boot/index.js",
  "module": "client/dist/bundle.js",
  "author": "Dylan Wagstaff",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "parcel build",
    "dev": "parcel",
    "watch": "parcel watch",
    "lint": "eslint client/src && sass-lint client/src"
  },
  "dependencies": {
    "@bbob/parser": "^2.8.1",
    "babel-polyfill": "6.7.4",
    "is-hotkey": "^0.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "slate": "<1",
    "slate-history": "<1",
    "slate-react": "<1"
  },
  "peerDependencies": {
    "silverstripe-admin": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "silverstripe-admin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@silverstripe/eslint-config": "^0.0.5",
    "parcel": "^2.7.0",
    "parcel-plugin-externals": "^0.5.2"
  },
  "externals": [
    "jquery => jQuery"
  ],
  "jest": {
    "roots": [
      "client/src"
    ],
    "modulePaths": [
      "client/src",
      "../admin/client/src",
      "../admin/node_modules",
      "../silverstripe/admin/client/src",
      "../silverstripe/admin/node_modules",
      "../../silverstripe/admin/client/src",
      "../../silverstripe/admin/node_modules"
    ]
  }
}
